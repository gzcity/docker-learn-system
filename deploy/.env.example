# ============================================================
# Docker 源码学习系统 — 环境变量配置
# ============================================================
# 复制此文件为 .env，按需修改
# cp .env.example .env
# ============================================================

# ---- 核心配置 ----
# Agent 端口
APP_PORT=8080

# 默认人格（socratic | professor | practitioner | storyteller | coach | debugger | minimalist | devils_advocate）
ACTIVE_PERSONA=socratic

# 日志级别（debug | info | warning | error）
LOG_LEVEL=info

# ---- 数据库 ----
# Neo4j 密码（首次启动时设置）
NEO4J_PASSWORD=learn1234

# Neo4j 端口
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Neo4j 内存配置（根据主机内存调整）
NEO4J_CACHE_SIZE=512M
NEO4J_HEAP_INIT=512M
NEO4J_HEAP_MAX=1G

# ChromaDB 端口
CHROMA_PORT=8000

# ---- Docker 源码 ----
# Docker 源码路径（挂载到容器中供学习系统读取）
# 如果为空，系统会从 GitHub 自动克隆
DOCKER_SOURCE_PATH=./volumes/docker-source