# ============================================================
# Docker 构建忽略列表
# ============================================================

# 版本控制
.git
.gitignore

# IDE
.vscode
.idea
*.swp

# 系统文件
.DS_Store
Thumbs.db

# 构建产物
__pycache__
*.pyc
*.pyo
*.egg-info
dist
build

# 环境配置（不包含在镜像中，通过 volume 挂载）
.env
.env.local

# 运行时数据（通过 volume 挂载）
volumes/

# 文档（设计文档不需要在运行镜像中）
README.md
ARCHITECTURE.md
ROADMAP.md
OVERVIEW.md